{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "isigroup",
  "version": "0.1.4",
  "identifier": "br.com.isitools.isigroup",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build && pnpm prepare:bundle",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "isigroup",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "resources": ["resources/**/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/progestaodigital/isiGroup/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJDQUQ5OEI2RDM2NDE4RkQKUldUOUdHVFR0cGl0dklDZ3N0QWNIbEZQRlBzTDlBbzJaeWdHM01lbjVMY1VleDdBSzUvMEJ5VlcK"
    }
  }
}
